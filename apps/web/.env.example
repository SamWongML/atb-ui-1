# apps/web environment variables.
# Copy the lines you need into .env.local (gitignored) and set them.

# --- Backend endpoints ---
# Required in real deploys. Leave unset for same-origin (the default), which is
# also what the MSW dev mock below relies on.
# NEXT_PUBLIC_ATB_API_URL=https://api.example.com
# NEXT_PUBLIC_ATB_GATEWAY_WS_URL=wss://gateway.example.com/ws

# --- Dev only: mock the API with MSW (Mock Service Worker) ---
# When set to 1 in development, the app runs against in-browser fakes so the
# real login flow (email -> OTP -> verify) works with no backend. Keep the API
# URL above unset so requests stay same-origin for the worker to intercept.
# Physically stripped from production builds.
# NEXT_PUBLIC_ATB_MOCK_API=1
