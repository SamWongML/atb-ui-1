# =====================================================================
# auto-tobe web frontend — environment
# =====================================================================
# This is the extracted frontend workspace. It has no bundled backend:
# the app talks to the auto-tobe `api` (HTTP) and `gateway` (WebSocket)
# services, whose origins are configured below. Runtime config that used
# to live here (PostHog key, Google OAuth client id, signup gating) is
# delivered by the api's /api/config endpoint, so it is NOT set here.

# ---------------------------------------------------------------------
# Backend endpoints (required)
# ---------------------------------------------------------------------
# Base URL of the auto-tobe `api` service. All HTTP requests (/api/*,
# /auth/*) are sent to this origin. Leave empty only if the app is served
# same-origin behind a proxy that forwards to the api.
# Example: https://api.auto-tobe.example
NEXT_PUBLIC_ATB_API_URL=

# WebSocket URL of the auto-tobe `gateway` service (a distinct origin from
# the api). The realtime feed connects here; leave empty to run with the
# realtime feed dormant. Note the `/ws` path and the ws:// (or wss://) scheme.
# Example: wss://gateway.auto-tobe.example/ws
NEXT_PUBLIC_ATB_GATEWAY_WS_URL=

# ---------------------------------------------------------------------
# Frontend (optional)
# ---------------------------------------------------------------------
# Build-time version string surfaced to the api as X-Client-Version (logs /
# metrics). CI typically sets this to a git tag or short sha.
NEXT_PUBLIC_APP_VERSION=

# Dev server host/port. FRONTEND_ORIGIN also feeds the Playwright baseURL.
FRONTEND_PORT=3000
FRONTEND_ORIGIN=http://localhost:3000

# Comma-separated extra origins the Next.js dev server should accept for
# cross-origin HMR / webpack requests (e.g. a Tailscale IP). Optional.
# Example: CORS_ALLOWED_ORIGINS=http://100.x.y.z:3000
CORS_ALLOWED_ORIGINS=
