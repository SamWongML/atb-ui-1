{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "FRONTEND_PORT",
    "FRONTEND_ORIGIN",
    "NEXT_PUBLIC_ATB_API_URL",
    "NEXT_PUBLIC_ATB_GATEWAY_WS_URL",
    "NEXT_PUBLIC_APP_VERSION",
    "CORS_ALLOWED_ORIGINS",
    "STANDALONE"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "app/**", "**/*.ts", "**/*.tsx", "**/*.css"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "out/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^typecheck"]
    },
    "lint": {
      "dependsOn": ["^typecheck"]
    }
  }
}
